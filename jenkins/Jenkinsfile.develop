pipeline {
    agent { label 'linux-docker' }

    options {
        buildDiscarder(logRotator(numToKeepStr: '50'))
        disableConcurrentBuilds()
        skipDefaultCheckout(true)
        timestamps()
        timeout(time: 60, unit: 'MINUTES')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Resolve Revision') {
            steps {
                script {
                    env.FULL_COMMIT = sh(script: 'git rev-parse HEAD', returnStdout: true).trim()
                    env.SHORT_COMMIT = sh(script: 'git rev-parse --short=8 HEAD', returnStdout: true).trim()
                    env.LOCAL_IMAGE = "ci-ai-codereview-ci:${env.BUILD_NUMBER}-${env.SHORT_COMMIT}"
                    env.RELEASE_ARCHIVE = "ci-ai-codereview-${env.FULL_COMMIT}.tar.gz"
                    currentBuild.description = "${env.BRANCH_NAME ?: 'unknown'} ${env.SHORT_COMMIT}"
                }
            }
        }

        stage('Build Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'gitlab-registry-read',
                    usernameVariable: 'REGISTRY_USER',
                    passwordVariable: 'REGISTRY_PASSWORD'
                )]) {
                    sh '''
                        set -eu
                        : "${CI_IMAGE_REPOSITORY:?Configure CI_IMAGE_REPOSITORY in Jenkins global properties}"
                        REGISTRY_HOST="${CI_IMAGE_REPOSITORY%%/*}"
                        DOCKER_CONFIG="$(mktemp -d)"
                        export DOCKER_CONFIG
                        chmod 700 "$DOCKER_CONFIG"
                        trap 'docker logout "$REGISTRY_HOST" >/dev/null 2>&1 || true; rm -rf "$DOCKER_CONFIG"' EXIT
                        set +x
                        printf '%s' "$REGISTRY_PASSWORD" | docker login "$REGISTRY_HOST" \
                            --username "$REGISTRY_USER" --password-stdin
                        set -x
                        PYTHON_BASE_IMAGE_VALUE="${PYTHON_BASE_IMAGE:-python:3.12-slim}"
                        docker build --pull \
                            --build-arg "PYTHON_BASE_IMAGE=$PYTHON_BASE_IMAGE_VALUE" \
                            --label "org.opencontainers.image.revision=$FULL_COMMIT" \
                            --label "org.opencontainers.image.source=${GIT_URL:-unknown}" \
                            --tag "$LOCAL_IMAGE" .
                    '''
                }
            }
        }

        stage('Unit Tests') {
            steps {
                sh '''
                    set -eu
                    docker run --rm \
                        -e APP_ENABLE_SCHEDULER=false \
                        -e LLM_MOCK_ENABLED=true \
                        -e MONGO_MOCK=true \
                        "$LOCAL_IMAGE" python -m pytest -q
                '''
            }
        }

        stage('Publish Commit Image') {
            when {
                expression { env.BRANCH_NAME in ['develop', 'development', 'master'] }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'gitlab-registry-push',
                    usernameVariable: 'REGISTRY_USER',
                    passwordVariable: 'REGISTRY_PASSWORD'
                )]) {
                    sh '''
                        set -eu
                        : "${CI_IMAGE_REPOSITORY:?Configure CI_IMAGE_REPOSITORY in Jenkins global properties}"
                        REGISTRY_HOST="${CI_IMAGE_REPOSITORY%%/*}"
                        DOCKER_CONFIG="$(mktemp -d)"
                        export DOCKER_CONFIG
                        chmod 700 "$DOCKER_CONFIG"
                        trap 'docker logout "$REGISTRY_HOST" >/dev/null 2>&1 || true; rm -rf "$DOCKER_CONFIG"' EXIT
                        set +x
                        printf '%s' "$REGISTRY_PASSWORD" | docker login "$REGISTRY_HOST" \
                            --username "$REGISTRY_USER" --password-stdin
                        set -x
                        docker tag "$LOCAL_IMAGE" "$CI_IMAGE_REPOSITORY:$FULL_COMMIT"
                        docker push "$CI_IMAGE_REPOSITORY:$FULL_COMMIT"
                        docker tag "$LOCAL_IMAGE" "$CI_IMAGE_REPOSITORY:$BRANCH_NAME"
                        docker push "$CI_IMAGE_REPOSITORY:$BRANCH_NAME"
                    '''
                }
            }
        }

        stage('Package Source Snapshot') {
            when {
                expression { env.BRANCH_NAME in ['develop', 'development', 'master'] }
            }
            steps {
                sh '''
                    set -eu
                    git archive --format=tar "$FULL_COMMIT" | gzip -9 > "$RELEASE_ARCHIVE"
                    sha256sum "$RELEASE_ARCHIVE" > "$RELEASE_ARCHIVE.sha256"
                '''
                archiveArtifacts artifacts: 'ci-ai-codereview-*.tar.gz,ci-ai-codereview-*.tar.gz.sha256', fingerprint: true
            }
        }

        stage('Deploy Development') {
            when {
                expression { env.BRANCH_NAME in ['develop', 'development', 'master'] }
            }
            steps {
                withCredentials([
                    sshUserPrivateKey(
                        credentialsId: 'dev-deploy-ssh',
                        keyFileVariable: 'SSH_KEY_FILE',
                        usernameVariable: 'SSH_USER'
                    ),
                    file(credentialsId: 'deploy-known-hosts', variable: 'SSH_KNOWN_HOSTS')
                ]) {
                    sh '''
                        set -eu
                        : "${DEV_DEPLOY_HOST:?Configure DEV_DEPLOY_HOST in Jenkins global properties}"
                        : "${DEV_DEPLOY_ROOT:?Configure DEV_DEPLOY_ROOT in Jenkins global properties}"
                        sh scripts/jenkins_deploy_release.sh \
                            --host "$DEV_DEPLOY_HOST" \
                            --port "${DEV_DEPLOY_PORT:-22}" \
                            --root "$DEV_DEPLOY_ROOT" \
                            --environment dev \
                            --archive "$RELEASE_ARCHIVE" \
                            --checksum "$RELEASE_ARCHIVE.sha256" \
                            --image "$CI_IMAGE_REPOSITORY:$FULL_COMMIT" \
                            --commit "$FULL_COMMIT"
                    '''
                }
            }
        }

        stage('Promote Master Release') {
            when { branch 'master' }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'gitlab-registry-push',
                    usernameVariable: 'REGISTRY_USER',
                    passwordVariable: 'REGISTRY_PASSWORD'
                )]) {
                    sh '''
                        set -eu
                        REGISTRY_HOST="${CI_IMAGE_REPOSITORY%%/*}"
                        DOCKER_CONFIG="$(mktemp -d)"
                        export DOCKER_CONFIG
                        chmod 700 "$DOCKER_CONFIG"
                        trap 'docker logout "$REGISTRY_HOST" >/dev/null 2>&1 || true; rm -rf "$DOCKER_CONFIG"' EXIT
                        set +x
                        printf '%s' "$REGISTRY_PASSWORD" | docker login "$REGISTRY_HOST" \
                            --username "$REGISTRY_USER" --password-stdin
                        set -x
                        RELEASE_IMAGE="$CI_IMAGE_REPOSITORY:release-$FULL_COMMIT"
                        LOCAL_IMAGE_ID="$(docker image inspect --format '{{.Id}}' "$LOCAL_IMAGE")"
                        if docker manifest inspect "$RELEASE_IMAGE" >/dev/null 2>&1; then
                            docker pull "$RELEASE_IMAGE"
                            RELEASE_IMAGE_ID="$(docker image inspect --format '{{.Id}}' "$RELEASE_IMAGE")"
                            [ "$RELEASE_IMAGE_ID" = "$LOCAL_IMAGE_ID" ] || {
                                echo "Existing immutable release does not match the tested image" >&2
                                exit 2
                            }
                            echo "Release image already exists and matches: $RELEASE_IMAGE"
                        else
                            docker tag "$LOCAL_IMAGE" "$RELEASE_IMAGE"
                            docker push "$RELEASE_IMAGE"
                        fi
                    '''
                }
                script {
                    currentBuild.displayName = "#${env.BUILD_NUMBER} ${env.SHORT_COMMIT}"
                    currentBuild.description = "master deployed to development"
                }
            }
        }
    }

    post {
        always {
            sh returnStatus: true, script: '''
                if [ -n "${LOCAL_IMAGE:-}" ]; then
                    docker image rm "$LOCAL_IMAGE" >/dev/null 2>&1 || true
                fi
            '''
        }
    }
}
