APP_NAME=ci-ai-codereview
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENABLE_SCHEDULER=false
SCHEDULER_INTERVAL_SECONDS=300

MONGODB_URI=mongodb://mongodb:27017/ci_ai_codereview
MONGODB_DB=ci_ai_codereview
MONGO_MOCK=false

LLM_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=120
LLM_CONCURRENCY=4
LLM_MAX_TOOL_ROUNDS=30
LLM_JSON_RETRY_TIMES=2
LLM_MOCK_ENABLED=true

DIFF_TOKEN_THRESHOLD=10000
DIFF_CONTEXT_LINES=10
CODE_REPOSITORY_ROOT=
REVIEW_EXCLUDE_DIRS=.git,__pycache__,node_modules,.venv,venv,dist,build,.pytest_cache

MOCK_PROJECT_ID=mock-project
MOCK_PARENT_PATH=
MOCK_COPY_FROM_VERSION=
MOCK_REVIEW_VERSION=/app
MOCK_TASK_TYPE=2
